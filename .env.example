# Copia questo file in .env e compila i valori:
#   cp .env.example .env && chmod 600 .env
#
# Database (backup-db.sh)
DB_BACKUP_USER=
DB_BACKUP_PASSWORD=

# Percorsi locali
BACKUP_DB_DIR=/home/ubuntu/backup-db
BACKUP_FILES_ROOT=/home/ubuntu/backup
SOURCE_WEB_DIR=/var/www/html
WEB_ROOT=/var/www
ERROR_LOG_BACKUP_FILES=/home/ubuntu/errors_backup_files.log

# Rclone (nome remote e percorsi sul cloud)
RCLONE_REMOTE_DB=gdrive:backup-mia-vps/db
RCLONE_REMOTE_FILES=gdrive:backup-mia-vps/files
# backup-files.sh: prima del backup, rimuove su Drive (solo questo percorso) i file più vecchi di N giorni
BACKUP_FILES_REMOTE_RETENTION_DAYS=90

# Telegram (backup-files.sh, rclone-health.sh)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
